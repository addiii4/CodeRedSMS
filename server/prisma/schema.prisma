generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                 String          @id @default(uuid())
  code               String          @unique
  name               String
  senderId           String?
  credits            Int             @default(0)
  smsglobalKeyEnc    String?
  smsglobalSecretEnc String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  contacts           Contact[]
  ledger             CreditsLedger[]
  devices            Device[]
  groups             Group[]
  users              Membership[]
  messages           Message[]
  templates          Template[]
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  passwordHash String
  displayName  String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  devices      Device[]
  memberships  Membership[]
}

model Membership {
  id        String       @id @default(uuid())
  userId    String
  orgId     String
  role      Role
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
}

model Contact {
  id           String        @id @default(uuid())
  orgId        String
  fullName     String
  phoneE164    String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  org          Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  groupMembers GroupMember[]

  @@index([orgId, phoneE164])
}

model Group {
  id          String        @id @default(uuid())
  orgId       String
  name        String
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  org         Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  members     GroupMember[]
}

model GroupMember {
  id        String  @id @default(uuid())
  groupId   String
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  group     Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, contactId])
}

model Template {
  id        String       @id @default(uuid())
  orgId     String
  title     String
  body      String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model Message {
  id          String             @id @default(uuid())
  orgId       String
  authorId    String
  title       String
  body        String
  scheduledAt DateTime?
  status      MessageStatus      @default(draft)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  org         Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  recipients  MessageRecipient[]
}

model MessageRecipient {
  id            String    @id @default(uuid())
  messageId     String
  contactId     String?
  phoneE164     String
  providerMsgId String?
  status        String    @default("queued")
  deliveredAt   DateTime?
  errorCode     String?
  message       Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model CreditsLedger {
  id              String       @id @default(uuid())
  orgId           String
  type            LedgerType
  amount          Int
  reason          String
  stripePaymentId String?
  createdAt       DateTime     @default(now())
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model Device {
  id         String       @id @default(uuid())
  orgId      String
  userId     String?
  deviceId   String
  platform   String?
  pushToken  String?
  lastSeenAt DateTime     @default(now())
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user       User?        @relation(fields: [userId], references: [id])

  @@unique([orgId, deviceId])
  @@index([userId])
}

enum Role {
  admin
  editor
  viewer
}

enum MessageStatus {
  draft
  queued
  sending
  sent
  failed
}

enum LedgerType {
  credit
  debit
}
